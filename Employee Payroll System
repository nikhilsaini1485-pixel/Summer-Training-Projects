def log_salary(func):
    def wrapper(self):
        salary = func(self)
        print(f"[LOG] Salary calculated for {self.name}: {salary}")
        with open("salary_log.txt", "a") as f:
            f.write(self.name + "," + str(salary) + "\n")
        return salary
    return wrapper


class Employee:
    def __init__(self, name):
        self.name = name

    def calculate_salary(self):
        pass


class FullTimeEmployee(Employee):
    def __init__(self, name, salary):
        super().__init__(name)
        self.salary = salary

    @log_salary
    def calculate_salary(self):
        return self.salary


class PartTimeEmployee(Employee):
    def __init__(self, name, hours, rate):
        super().__init__(name)
        self.hours = hours
        self.rate = rate

    @log_salary
    def calculate_salary(self):
        return self.hours * self.rate


# Demo
e1 = FullTimeEmployee("Aman", 50000)
e2 = PartTimeEmployee("Riya", 100, 200)

e1.calculate_salary()
e2.calculate_salary()
